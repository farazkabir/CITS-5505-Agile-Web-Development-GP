{% extends "base.html" %}

{% block title %}Profile | NewsPulse{% endblock %}

{% block body %}
<div class="app-shell">
    <aside class="sidebar d-none d-lg-block">
        {% include "_sidebar.html" %}
    </aside>
    <main class="app-main">
        <div class="feed-container">
            {% include "_flash.html" %}
            <div class="user-profile-header glass rounded-3 p-4 mb-4">
    <div class="d-flex align-items-center gap-4 flex-wrap">
        <div class="user-profile-avatar">
            {{ profile_user.name[:1]|upper }}
        </div>
        <div class="flex-fill">
            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                <h1 class="fs-4 fw-bold mb-0">{{ profile_user.name }}</h1>
                {% if is_own_profile %}
                <span class="badge rounded-pill"
                      style="background: color-mix(in srgb, var(--primary), transparent 85%);
                             color: var(--primary); font-size: 0.65rem;">You</span>
                {% endif %}
            </div>
            <p class="text-body-secondary small mb-0">
                <i class="bi bi-calendar3 me-1"></i>Joined {{ joined }}
            </p>
            <div class="d-flex gap-4 flex-wrap mt-3">
    <div class="text-center">
        <div class="fw-bold" style="color: var(--primary)">{{ comment_count }}</div>
        <div class="text-body-secondary" style="font-size: 0.7rem;">Comments</div>
    </div>
    <div class="text-center">
        <div class="fw-bold" style="color: var(--accent)">{{ voted_count }}</div>
        <div class="text-body-secondary" style="font-size: 0.7rem;">Posts Voted</div>
    </div>
    <div class="text-center">
        <div class="fw-bold" style="color: var(--chart-3)">{{ posts_commented_count }}</div>
        <div class="text-body-secondary" style="font-size: 0.7rem;">Posts Commented</div>
    </div>
</div>        </div>
        {% if is_own_profile %}
        <a href="{{ url_for('main.account') }}" class="btn btn-sm btn-outline-secondary align-self-start">
            <i class="bi bi-pencil me-1"></i>Edit Profile
        </a>
        {% endif %}
    </div>
</div>        </div>
<ul class="nav account-tabs mb-4">
    <li class="nav-item">
        <button class="account-tab active" data-bs-toggle="tab" data-bs-target="#commented-pane" type="button">
            <i class="bi bi-chat-square"></i> Comments
            <span class="user-tab-count">{{ comment_count }}</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="account-tab" data-bs-toggle="tab" data-bs-target="#voted-pane" type="button">
            <i class="bi bi-caret-up"></i> Voted Posts
            <span class="user-tab-count">{{ voted_count }}</span>
        </button>
    </li>
</ul>
<div class="tab-content">
    <div class="tab-pane fade show active" id="commented-pane" role="tabpanel">
        <!-- comments coming soon -->
    </div>
    <div class="tab-pane fade" id="voted-pane" role="tabpanel">
        <!-- voted posts coming soon -->
    </div>
</div>    </main>
</div>
{% endblock %}
